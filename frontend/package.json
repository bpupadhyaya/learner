{
  "name": "learning-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run tests/unit --coverage.enabled --coverage.provider=v8 --coverage.reportsDirectory=coverage/unit --coverage.reporter=text --coverage.reporter=lcov --coverage.include=src/App.tsx --coverage.include=src/api.ts --coverage.include=src/main.tsx --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100 --coverage.thresholds.branches=100",
    "test:integration": "vitest run tests/integration --coverage.enabled --coverage.provider=v8 --coverage.reportsDirectory=coverage/integration --coverage.reporter=text --coverage.reporter=lcov --coverage.include=src/App.tsx --coverage.include=src/api.ts --coverage.include=src/main.tsx --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100 --coverage.thresholds.branches=100"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  }
}
